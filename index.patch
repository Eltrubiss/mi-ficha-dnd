         details > summary::-webkit-details-marker {
             display: none;
         }
         /* Agregamos nuestro propio indicador de flecha con CSS */
         details > summary::before {
             content: '▶';
             font-size: 12px;
             margin-right: 8px;
             display: inline-block;
             transition: transform 0.2s ease-in-out;
